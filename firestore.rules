rules_version = '2';

// Tier 1 anti-cheat: client is trusted for the score calculation itself, but
// writes are rate-limited, score cannot go down, and per-write deltas are
// capped. Tier 2 will add a Cloud Function that recomputes the score from
// collect events server-side.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Leaderboard is world-readable for any signed-in user (including
      // anonymous accounts). We do not expose the uid itself anywhere, and
      // the displayName is chosen by the user for public display.
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUser(request.resource.data)
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 5000
                    && request.resource.data.fossilCount >= 0
                    && request.resource.data.fossilCount <= 100;

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && validUser(request.resource.data)
                    // Monotonic score — no wipes, no replays of lower scores.
                    && request.resource.data.score >= resource.data.score
                    // Per-write delta cap (one shiny chroma is worth 2000).
                    && request.resource.data.score - resource.data.score <= 5000
                    && request.resource.data.fossilCount >= resource.data.fossilCount
                    // Rate limit: ≥3 seconds between writes per user.
                    && request.time > resource.data.updatedAt + duration.value(3, 's');

      // No deletes — scores are permanent once earned.
      allow delete: if false;
    }

    // Everything outside /users is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validUser(data) {
  return data.keys().hasAll(['displayName', 'score', 'fossilCount', 'updatedAt'])
      && data.displayName is string
      && data.displayName.size() >= 1
      && data.displayName.size() <= 24
      && data.score is number
      && data.score >= 0
      && data.fossilCount is number
      && data.fossilCount >= 0
      && data.updatedAt is timestamp;
}
